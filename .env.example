# ===========================================
# AI 面试助手 - 环境变量配置
# 复制此文件为 .env 并填入实际值
# ===========================================

# 数据库配置
DB_URL=jdbc:mysql://localhost:3306/face_ai_interview?useUnicode=true&characterEncoding=UTF-8&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&useSSL=false
DB_USERNAME=root
DB_PASSWORD=your_db_password

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379

# AI 服务 (DashScope)
AI_API_KEY=sk-your-dashscope-api-key

# JWT 认证密钥 (至少24字符)
JWT_SECRET=your-jwt-secret-must-be-at-least-24-characters

# OCR 数据路径 (Tesseract tessdata 目录)
OCR_DATA_PATH=./tessdata
